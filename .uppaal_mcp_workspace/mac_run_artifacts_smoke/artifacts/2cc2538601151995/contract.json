  "policies": [
    {
      "name": "P0",
      "guard": "resourceClass == RES_EXHAUSTED || mappedResourceClass == RES_EXHAUSTED",
      "mode": "SCH_CONSTRAINED",
      "outcome": "resource_reject! or mac_report! by D_sched",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P1",
      "guard": "bufferClass == B_OVERFLOW || delayClass == D_VIOLATED",
      "mode": "SCH_COMM",
      "outcome": "protect communication and report SDN/RIC",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P2",
      "guard": "queueClass == Q_CRIT && commDemand == COMM_CRITICAL",
      "mode": "SCH_COMM",
      "outcome": "mac_schedule_cmd! or mac_report!",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P3",
      "guard": "sensingDemand == SENS_CRITICAL && SDN allows sensing priority",
      "mode": "SCH_SENS or SCH_JOINT",
      "outcome": "sensing_boost_cmd! or constrained_mode_cmd!",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P4",
      "guard": "resourceClass == RES_TIGHT and both demands active",
      "mode": "SCH_JOINT or SCH_CONSTRAINED",
      "outcome": "joint scheduling or deficit report",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P5",
      "guard": "KPIFreshnessClass stale or missing",
      "mode": "SCH_CONSTRAINED",
      "outcome": "avoid aggressive reconfiguration",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P6",
      "guard": "ResourceClass free or balanced",
      "mode": "SCH_JOINT",
      "outcome": "ordinary ISAC schedule",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    },
    {
      "name": "P7",
      "guard": "fallback",
      "mode": "SCH_CONSTRAINED",
      "outcome": "safe fallback",
      "provenance": {
        "source": "MAC_resource_scheduling_formalization.tex",
        "section": "MAC policies",
        "line": null
      }
    }
  ],
