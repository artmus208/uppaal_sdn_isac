<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC "-//Uppaal Team//DTD Flat System 1.6//EN" "http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd">
<nta>
  <declaration>const int D_sense = 5;
clock c_obs, c_driver;
broadcast chan aos_ctrl_expired, sensing_report;
typedef int[0,1] SensingStateT;
const int SENSINGSTATE_SENSINGQOSOK = 0;
const int SENSINGSTATE_FRESHNESSLIMITED = 1;
SensingStateT SensingState = SENSINGSTATE_SENSINGQOSOK;</declaration>
  <template>
    <name>Template_Driver</name>
    <location id="Template_Driver_0" x="0" y="0">
      <name x="-20" y="-30">Start</name>
    </location>
    <location id="Template_Driver_1" x="180" y="0">
      <name x="160" y="-30">WaitResponse</name>
    </location>
    <location id="Template_Driver_2" x="360" y="0">
      <name x="340" y="-30">Done</name>
    </location>
    <init ref="Template_Driver_0" />
    <transition>
      <source ref="Template_Driver_0" />
      <target ref="Template_Driver_1" />
      <label kind="synchronisation" x="0" y="-60">aos_ctrl_expired!</label>
      <label kind="assignment" x="0" y="-40">c_driver = 0, SensingState = SENSINGSTATE_FRESHNESSLIMITED</label>
    </transition>
    <transition>
      <source ref="Template_Driver_2" />
      <target ref="Template_Driver_2" />
    </transition>
  </template>
  <template>
    <name>Template_ObsFreshness</name>
    <location id="Template_ObsFreshness_0" x="0" y="0">
      <name x="-20" y="-30">Idle</name>
    </location>
    <location id="Template_ObsFreshness_1" x="180" y="0">
      <name x="160" y="-30">Wait</name>
    </location>
    <location id="Template_ObsFreshness_2" x="360" y="0">
      <name x="340" y="-30">Violation</name>
    </location>
    <init ref="Template_ObsFreshness_0" />
    <transition>
      <source ref="Template_ObsFreshness_0" />
      <target ref="Template_ObsFreshness_1" />
      <label kind="synchronisation" x="0" y="-60">aos_ctrl_expired?</label>
      <label kind="assignment" x="0" y="-40">c_obs = 0</label>
    </transition>
    <transition>
      <source ref="Template_ObsFreshness_1" />
      <target ref="Template_ObsFreshness_0" />
      <label kind="guard" x="0" y="-60">c_obs &lt;= D_sense &amp;&amp; SensingState == SENSINGSTATE_FRESHNESSLIMITED</label>
      <label kind="synchronisation" x="0" y="-40">sensing_report?</label>
    </transition>
    <transition>
      <source ref="Template_ObsFreshness_1" />
      <target ref="Template_ObsFreshness_2" />
      <label kind="guard" x="0" y="-60">c_obs &gt; D_sense</label>
    </transition>
    <transition>
      <source ref="Template_ObsFreshness_0" />
      <target ref="Template_ObsFreshness_0" />
    </transition>
    <transition>
      <source ref="Template_ObsFreshness_2" />
      <target ref="Template_ObsFreshness_2" />
    </transition>
  </template>
  <system>Driver = Template_Driver();
ObsFreshness = Template_ObsFreshness();
system Driver, ObsFreshness;</system>
</nta>
